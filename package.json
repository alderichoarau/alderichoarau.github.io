{
  "name": "alderichoarau-portfolio-temp",
  "version": "1.8.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:gh-pages": "ng build --configuration production --base-href=/",
    "a11y": "axe http://localhost:4200",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "ng lint --max-warnings=0",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,js,html,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,html,scss,css,json}\"",
    "check": "npm run lint && npm run format:check",
    "pre-commit": "lint-staged",
    "pre-commit-full": "npm run test && npm run lint && npm run build:prod",
    "quality-gate": "npm run format:check && npm run lint && npm run test && npm run build:prod",
    "security:audit": "npm audit --audit-level=high && (npm outdated | grep -v 'alpha\\|beta' || true)",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.16",
    "@angular/cdk": "21.2.14",
    "@angular/common": "21.2.16",
    "@angular/compiler": "21.2.16",
    "@angular/core": "21.2.16",
    "@angular/forms": "21.2.16",
    "@angular/material": "21.2.14",
    "@angular/platform-browser": "21.2.16",
    "@angular/platform-browser-dynamic": "21.2.16",
    "@angular/router": "21.2.16",
    "@angular/service-worker": "21.2.16",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@analogjs/vitest-angular": "^2.6.1",
    "@angular/build": "21.2.14",
    "@angular/cli": "21.2.14",
    "@angular/compiler-cli": "21.2.16",
    "@axe-core/cli": "4.11.3",
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "angular-eslint": "21.4.0",
    "eslint": "10.4.1",
    "husky": "9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "prettier --write"
    ],
    "src/**/*.{html,scss,css,json,md}": [
      "prettier --write"
    ]
  }
}